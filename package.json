{
  "name": "hibiki-codex",
  "productName": "Hibiki Codex",
  "version": "0.0.3-beta",
  "description": "Live system-audio transcription with an AI sidekick (Claude / Codex). hibikicodex.com",
  "homepage": "https://hibikicodex.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brunolm/hibiki-codex.git"
  },
  "bugs": {
    "url": "https://github.com/brunolm/hibiki-codex/issues"
  },
  "author": {
    "name": "brunolm",
    "email": "brunolm7@gmail.com",
    "url": "https://github.com/brunolm"
  },
  "main": "out/main/index.js",
  "scripts": {
    "fetch:whisper": "node scripts/fetch-whisper.mjs",
    "dev": "node scripts/fetch-whisper.mjs && electron-vite dev",
    "build": "node scripts/fetch-whisper.mjs && electron-vite build",
    "build:rust": "bun run --cwd native build",
    "build:rust:debug": "bun run --cwd native build:debug",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "bun run build:rust && bun run build && electron-builder --win",
    "dist:dir": "bun run build:rust && bun run build && electron-builder --win --dir",
    "package:win": "electron-builder --win --publish never",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:serve": "bun scripts/build-docs.mjs --serve"
  },
  "build": {
    "appId": "com.brunolm.hibikicodex",
    "productName": "Hibiki Codex",
    "copyright": "Copyright © 2026 brunolm",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/.{git,DS_Store,vscode,idea}",
      "!**/{tsconfig*.json,electron.vite.config.*,bun.lock,package-lock.json}"
    ],
    "extraResources": [
      {
        "from": "resources/wasapi-loopback.ps1",
        "to": "wasapi-loopback.ps1"
      },
      {
        "from": "resources/app-icon.png",
        "to": "app-icon.png"
      },
      {
        "from": "resources/whisper",
        "to": "whisper",
        "filter": [
          "**/*",
          "!README.md",
          "!.version"
        ]
      },
      {
        "from": "native",
        "to": "native",
        "filter": [
          "index.js",
          "package.json",
          "*.node"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/app-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hibiki Codex",
      "uninstallDisplayName": "Hibiki Codex"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "22.19.18",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "33.4.11",
    "electron-builder": "25.1.8",
    "electron-vite": "2.3.0",
    "html-minifier-terser": "7.2.0",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
